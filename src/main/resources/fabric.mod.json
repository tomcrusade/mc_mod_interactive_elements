{
  "schemaVersion": 1,
  "id": "interactiveelements",
  "version": "${version}",
  "name": "Elementary Metals",
  "description": "Collection of polished and feature-rich substance not exists in vanilla minecraft",
  "authors": [],
  "contact": {
    "homepage": "https://tomcrusade.com",
    "sources": ""
  },
  "license": "MIT",
  "icon": "assets/interactiveelements/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "org.tomcrusade.interactiveelements.InteractiveElementsClient"
    ],
    "main": [
      "org.tomcrusade.interactiveelements.InteractiveElements"
    ]
  },
  "mixins": [
    "interactiveelements.mixins.json",
    {
      "config": "interactiveelements.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  }
}
